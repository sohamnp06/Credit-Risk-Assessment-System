{
  "name": "credit-risk-system",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm run backend\" \"npm run frontend\"",
    "backend": "venv\\Scripts\\python.exe main.py",
    "frontend": "cd credit-risk-ui && npm run dev",
    "install:all": "cd credit-risk-ui && npm install"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  }
}
